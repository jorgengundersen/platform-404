#!/usr/bin/env bash
set -euo pipefail

# Ralph Wiggum Loop (minimal)
# Coined by Geoffrey Huntley - https://ghuntley.com/ralph
#
# Core idea: fresh context each iteration. One task per loop.
# The agent reads specs + prompt, picks a ready issue from beads (bd),
# implements it with backpressure (tests/build), closes the issue,
# and commits. Then the session ends and a fresh one starts.

# ---------------------------------------------------------------------------
# Defaults (adjust these)
# ---------------------------------------------------------------------------
DEFAULT_MODEL="github-copilot/gpt-5.3-codex"
DEFAULT_PROMPT=".ralph/DEFAULT_PROMPT.md"
DEFAULT_MAX_ITERATIONS=10
DEFAULT_DONE_FILE=".ralph/general.DONE"
DEFAULT_LOG_DIR=".ralph/logs/general"
DEFAULT_SLEEP_INTERVAL=60
DEFAULT_MAX_IDLE="100"
LOOP_TYPE="general"

# ---------------------------------------------------------------------------
# Resolve paths
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
  cat <<EOF
usage: ralph-loop [options]

options:
  -m, --model <model>           model to use (default: $DEFAULT_MODEL)
  -p, --prompt <file>           prompt file, relative to project root (default: $DEFAULT_PROMPT)
  -n, --max-iterations <n>      max loop iterations (default: $DEFAULT_MAX_ITERATIONS; ignored in daemon mode)
  -d, --daemon                  daemon mode: sleep when idle instead of exiting
      --sleep-interval <secs>   idle sleep duration in seconds (default: $DEFAULT_SLEEP_INTERVAL; daemon mode only)
      --max-idle <n>            max consecutive idle sleep cycles before exit (default: 100; daemon mode only)
  -h, --help                    show this help
EOF
  exit 0
}

# ---------------------------------------------------------------------------
# Parse args
# ---------------------------------------------------------------------------
MODEL="$DEFAULT_MODEL"
PROMPT_REL="$DEFAULT_PROMPT"
MAX_ITERATIONS="$DEFAULT_MAX_ITERATIONS"
DONE_FILE="$PROJECT_DIR/$DEFAULT_DONE_FILE"
LOG_DIR="$PROJECT_DIR/$DEFAULT_LOG_DIR"
DAEMON_MODE=false
SLEEP_INTERVAL="$DEFAULT_SLEEP_INTERVAL"
MAX_IDLE="$DEFAULT_MAX_IDLE"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -m|--model)          MODEL="$2"; shift 2 ;;
    -p|--prompt)         PROMPT_REL="$2"; shift 2 ;;
    -n|--max-iterations) MAX_ITERATIONS="$2"; shift 2 ;;
    -d|--daemon)         DAEMON_MODE=true; shift ;;
    --sleep-interval)    SLEEP_INTERVAL="$2"; shift 2 ;;
    --max-idle)          MAX_IDLE="$2"; shift 2 ;;
    -h|--help)           usage ;;
    *) echo "error: unknown option: $1" >&2; usage ;;
  esac
done

PROMPT_FILE="$PROJECT_DIR/$PROMPT_REL"

# ---------------------------------------------------------------------------
# Logging — timestamped log file per run, symlink 'latest'
# ---------------------------------------------------------------------------
RUN_TS="$(date '+%Y%m%dT%H%M%S')"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/${RUN_TS}_${LOOP_TYPE}_pid$$.log"
: > "$LOG_FILE"
ln -sf "$LOG_FILE" "$LOG_DIR/latest"

log() {
  local level="$1"; shift
  local ts
  ts="$(date '+%Y-%m-%dT%H:%M:%S%z')"
  printf '%s [%s] %s\n' "$ts" "$level" "$*" | tee -a "$LOG_FILE"
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
# Keep only issues labeled 'ok' (case-insensitive).
BD_READY_FILTERED() {
  bd ready --json 2>/dev/null | jq '[.[] | select(any((.labels // [])[]; ascii_downcase == "ok"))]'
}

# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------
if [[ ! -f "$PROMPT_FILE" ]]; then
  log ERROR "prompt file not found: $PROMPT_FILE"
  exit 1
fi

if ! command -v opencode &>/dev/null; then
  log ERROR "opencode not found in PATH"
  exit 1
fi

if ! command -v bd &>/dev/null; then
  log ERROR "bd (beads) not found in PATH"
  exit 1
fi

if ! [[ "$MAX_ITERATIONS" =~ ^[0-9]+$ ]] || [[ "$MAX_ITERATIONS" -lt 1 ]]; then
  log ERROR "max iterations must be a positive integer: $MAX_ITERATIONS"
  exit 1
fi

if ! [[ "$SLEEP_INTERVAL" =~ ^[0-9]+$ ]] || [[ "$SLEEP_INTERVAL" -lt 1 ]]; then
  log ERROR "sleep-interval must be a positive integer: $SLEEP_INTERVAL"
  exit 1
fi

if [[ -n "$MAX_IDLE" ]]; then
  if ! [[ "$MAX_IDLE" =~ ^[0-9]+$ ]] || [[ "$MAX_IDLE" -lt 1 ]]; then
    log ERROR "max-idle must be a positive integer: $MAX_IDLE"
    exit 1
  fi
fi

# ---------------------------------------------------------------------------
# Git remote check
# ---------------------------------------------------------------------------
ORIGIN_URL="$(git -C "$PROJECT_DIR" remote get-url origin 2>/dev/null || true)"
if [[ -n "$ORIGIN_URL" ]]; then
  log INFO "event=git_remote_detected origin=$ORIGIN_URL"
else
  log WARN "event=git_remote_missing msg=origin remote not configured"
fi

# ---------------------------------------------------------------------------
# Reset done file
# ---------------------------------------------------------------------------
: > "$DONE_FILE"

# ---------------------------------------------------------------------------
# Exit checks
# ---------------------------------------------------------------------------
check_done_file() {
  [[ -f "$DONE_FILE" ]] && grep -qi '^DONE$' "$DONE_FILE"
}

check_no_ready_work() {
  local ready
  ready="$(BD_READY_FILTERED)"
  [[ "$ready" == "[]" || "$ready" == "" ]]
}

# ---------------------------------------------------------------------------
# Main loop
# ---------------------------------------------------------------------------
RUN_START=$(date +%s)

log INFO "event=start loop_type=$LOOP_TYPE project=$PROJECT_DIR model=$MODEL prompt=$PROMPT_REL done_file=$DONE_FILE log_dir=$LOG_DIR max=$MAX_ITERATIONS daemon=$DAEMON_MODE sleep_interval=$SLEEP_INTERVAL max_idle=$MAX_IDLE log=$LOG_FILE ready_filter=exclude_experiment"

SESSIONS_RUN=0
IDLE_CYCLES=0
EXIT_REASON=""

# In daemon mode we loop indefinitely (until DONE or max_idle); otherwise cap at MAX_ITERATIONS.
# We use a while-true and break manually so daemon mode can ignore MAX_ITERATIONS.
LOOP_COUNT=0

while true; do
  LOOP_COUNT=$((LOOP_COUNT + 1))

  # --- guard: done file ---
  if check_done_file; then
    log INFO "event=done_file loop=$LOOP_COUNT msg=done file signals DONE"
    EXIT_REASON="done"
    break
  fi

  # --- guard: no ready work ---
  if check_no_ready_work; then
    if $DAEMON_MODE; then
      IDLE_CYCLES=$((IDLE_CYCLES + 1))
      log INFO "event=daemon_sleep loop=$LOOP_COUNT idle_cycle=$IDLE_CYCLES sleep=${SLEEP_INTERVAL}s max_idle=$MAX_IDLE"
      # Check max_idle threshold
      if [[ -n "$MAX_IDLE" ]] && [[ "$IDLE_CYCLES" -ge "$MAX_IDLE" ]]; then
        log INFO "event=max_idle loop=$LOOP_COUNT idle_cycles=$IDLE_CYCLES msg=max idle cycles reached"
        EXIT_REASON="max_idle"
        break
      fi
      sleep "$SLEEP_INTERVAL"
      log INFO "event=daemon_wake loop=$LOOP_COUNT idle_cycle=$IDLE_CYCLES"
      continue
    else
      log INFO "event=no_ready_work loop=$LOOP_COUNT msg=no ready issues in beads"
      EXIT_REASON="no_ready_work"
      break
    fi
  fi

  # Work is available — reset idle counter
  IDLE_CYCLES=0

  # --- guard: max iterations (normal mode only) ---
  if ! $DAEMON_MODE && [[ "$LOOP_COUNT" -gt "$MAX_ITERATIONS" ]]; then
    log WARN "event=max_iterations max=$MAX_ITERATIONS msg=max iterations reached"
    EXIT_REASON="max"
    break
  fi

  READY_COUNT="$(BD_READY_FILTERED | jq 'length' 2>/dev/null || echo '?')"
  if $DAEMON_MODE; then
    log INFO "event=session_start loop=$LOOP_COUNT ready=$READY_COUNT"
  else
    log INFO "event=session_start loop=$LOOP_COUNT/$MAX_ITERATIONS ready=$READY_COUNT"
  fi

  ITER_START=$(date +%s)
  PROMPT=$(cat "$PROMPT_FILE")
  set +e
  opencode run "$PROMPT" --model "$MODEL" --dir "$PROJECT_DIR" --thinking "true"
  SESSION_EXIT=$?
  set -e
  ITER_END=$(date +%s)

  if $DAEMON_MODE; then
    log INFO "event=session_end loop=$LOOP_COUNT exit_code=$SESSION_EXIT duration=$((ITER_END - ITER_START))s"
  else
    log INFO "event=session_end loop=$LOOP_COUNT/$MAX_ITERATIONS exit_code=$SESSION_EXIT duration=$((ITER_END - ITER_START))s"
  fi

  SESSIONS_RUN=$((SESSIONS_RUN + 1))

  # --- post-iteration check: done file ---
  if check_done_file; then
    log INFO "event=done_file loop=$LOOP_COUNT msg=done file signals DONE after session"
    EXIT_REASON="done"
    break
  fi

  # --- max iterations guard (normal mode, post-session) ---
  if ! $DAEMON_MODE && [[ "$SESSIONS_RUN" -ge "$MAX_ITERATIONS" ]]; then
    log WARN "event=max_iterations max=$MAX_ITERATIONS msg=max iterations reached"
    EXIT_REASON="max"
    break
  fi
done

REMAINING_READY="$(BD_READY_FILTERED | jq 'length' 2>/dev/null || echo '?')"
RUN_END=$(date +%s)
log INFO "event=finish sessions=$SESSIONS_RUN exit_reason=$EXIT_REASON remaining_ready=$REMAINING_READY total_duration=$((RUN_END - RUN_START))s"
